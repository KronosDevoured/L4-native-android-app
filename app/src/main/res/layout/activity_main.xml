<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootShell"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/renderSurfaceHost"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/topActionRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/menuBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu" />

        <Button
            android:id="@+id/themeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Theme" />

        <Button
            android:id="@+id/ringModeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Ring Mode"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/darModeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="150dp"
        android:layout_marginBottom="150dp"
        android:background="#66000000"
        android:clickable="false"
        android:longClickable="false"
        android:focusable="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp"
        android:text="Left"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/menuOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/menuPanel"
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:background="#222222"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="L4 Controls &amp; Settings"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/menuCloseBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Close" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rotationCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="#2E2E2E"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rotation"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/restartBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Restart" />

                        <Button
                            android:id="@+id/airRollModeBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Air Roll Mode: Hold" />

                        <Button
                            android:id="@+id/touchDarDirectionBtn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Touch DAR: Left" />

                        <TextView
                            android:id="@+id/gameSpeedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Game Speed: 100%"
                            android:textColor="#DDDDDD" />

                        <SeekBar
                            android:id="@+id/gameSpeedSeek"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="145"
                            android:progress="95" />

                        <TextView
                            android:id="@+id/touchDeadzoneValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Touch Deadzone: 0.09"
                            android:textColor="#DDDDDD" />

                        <SeekBar
                            android:id="@+id/touchDeadzoneSeek"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="50"
                            android:progress="9" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/gamepadCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="#2E2E2E"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gamepad"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/gamepadStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Status: Waiting for gamepad"
                            android:textColor="#DDDDDD" />

                        <TextView
                            android:id="@+id/gamepadBindingsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Default bindings: Toggle DAR = B / Circle · Air Roll Left = R1 / RB · Air Roll Right = L1 / LB · Air Roll (Free) = R2 / RT"
                            android:textColor="#DDDDDD" />

                        <TextView
                            android:id="@+id/gpLeftStickDeadzoneValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Left Stick Deadzone: 0.15"
                            android:textColor="#DDDDDD" />

                        <SeekBar
                            android:id="@+id/gpLeftStickDeadzoneSeek"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="50"
                            android:progress="15" />

                        <TextView
                            android:id="@+id/gpRightStickDeadzoneValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Right Stick Deadzone: 0.15"
                            android:textColor="#DDDDDD" />

                        <SeekBar
                            android:id="@+id/gpRightStickDeadzoneSeek"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="50"
                            android:progress="15" />

                        <TextView
                            android:id="@+id/gamepadDeferredText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Controls remapping and Dual Stick UI remain deferred for V1."
                            android:textColor="#DDDDDD" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/dynamicsCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="#2E2E2E"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dynamics"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/dynamicsAccelSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Pitch 733°/s² · Yaw 528°/s² · Roll 898°/s²"
                            android:textColor="#DDDDDD" />

                        <TextView
                            android:id="@+id/dynamicsDampSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Damp 2.96 · Damp (DAR) 4.35"
                            android:textColor="#DDDDDD" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/carCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:background="#2E2E2E"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Car"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/carBodySpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/viewHudCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#2E2E2E"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View &amp; HUD"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/stickSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Stick Size: 100"
                            android:textColor="#DDDDDD" />

                        <SeekBar
                            android:id="@+id/stickSizeSeek"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="120"
                            android:progress="40" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/ringModeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/ringModePanel"
            android:layout_width="520dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#222222"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rings Menu"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/ringModeCloseBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Close" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Game"
                android:textColor="#DDDDDD" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Audio"
                android:textColor="#DDDDDD" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
